# Supabase connection — copy this file to `.env.local` and fill in your values.
# Find both values in the Supabase dashboard: Project Settings → API.
# Only the anon/public key belongs in the browser; never put the service_role
# key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
